NODE_ENV=production
PORT=8000

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mechpro_experts?schema=public

# Comma-separated allowed frontend origins
CORS_ORIGIN=https://your-frontend-domain.com
PUBLIC_API_URL=https://your-backend-domain.com

# Use long random values in production
JWT_ACCESS_SECRET=replace_with_strong_random_access_secret
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Local for demo; switch to cloudinary/s3 when implemented
UPLOAD_DIR=uploads
STORAGE_PROVIDER=local
