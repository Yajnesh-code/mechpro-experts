generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES_PARTNER
  SERVICE_PARTNER
  CUSTOMER
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  mobile       String?  @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
